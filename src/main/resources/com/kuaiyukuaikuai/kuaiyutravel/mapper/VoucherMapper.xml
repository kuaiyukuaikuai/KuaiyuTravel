<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kuaiyukuaikuai.kuaiyutravel.mapper.VoucherMapper">

    <resultMap id="BaseResultMap" type="com.kuaiyukuaikuai.kuaiyutravel.entity.Voucher">
            <id property="id" column="id" />
            <result property="poiId" column="poi_id" />
            <result property="title" column="title" />
            <result property="subTitle" column="sub_title" />
            <result property="rules" column="rules" />
            <result property="payValue" column="pay_value" />
            <result property="actualValue" column="actual_value" />
            <result property="type" column="type" />
            <result property="status" column="status" />
            <result property="createTime" column="create_time" />
            <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="Base_Column_List">
        id,poi_id,title,sub_title,rules,pay_value,
        actual_value,type,status,create_time,update_time
    </sql>

    <select id="queryVoucherOfPoi" resultType="com.kuaiyukuaikuai.kuaiyutravel.entity.Voucher">
        SELECT v.*, sv.stock, sv.begin_time, sv.end_time
        FROM tb_voucher v
                 LEFT JOIN tb_seckill_voucher sv ON v.id = sv.voucher_id
        WHERE v.poi_id = #{poiId} AND v.status = 1
    </select>

</mapper>
